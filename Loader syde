-- ANIMATIONS
-- ════════════════════════════════════════════════════════════════════════════
local function setProgress(target, dur)
    tw(U.ProgFill, dur, {Size = UDim2.new(target/100, 0, 1, 0)}):Play()
    local start = State.pct
    local t0 = tick()
    task.spawn(function()
        while tick() - t0 < dur do
            local a = (tick() - t0) / dur
            local cur = start + (target - start) * a
            U.Pct.Text = math.floor(cur) .. "%"
            State.pct = cur
            task.wait()
        end
        U.Pct.Text = math.floor(target) .. "%"
        State.pct = target
    end)
end

local function setStatus(text)
    tw(U.Status, 0.12, {TextTransparency = 1}):Play()
    task.wait(0.12)
    U.Status.Text = text
    tw(U.Status, 0.12, {TextTransparency = 0}):Play()
end

local function activateDot(idx)
    if U.Dots[idx] then
        tw(U.Dots[idx], 0.3, {BackgroundColor3 = Config.AccentLt, Size = UDim2.new(0, 8, 0, 8)}):Play()
    end
end

local function pulseLoop()
    task.spawn(function()
        while not State.done and U.Card.Parent do
            tw(U.LogoGlow, 1.3, {BackgroundTransparency = 0.78, Size = UDim2.new(1.55, 0, 1.55, 0)}, Enum.EasingStyle.Sine):Play()
            tw(U.Stroke, 1.3, {Transparency = 0.2}, Enum.EasingStyle.Sine):Play()
            tw(U.ProgDot, 0.6, {BackgroundTransparency = 0, Size = UDim2.new(0, 16, 0, 16)}, Enum.EasingStyle.Sine):Play()
            task.wait(1.3)
            if State.done then break end
            tw(U.LogoGlow, 1.3, {BackgroundTransparency = 0.92, Size = UDim2.new(1.2, 0, 1.2, 0)}, Enum.EasingStyle.Sine):Play()
            tw(U.Stroke, 1.3, {Transparency = 0.5}, Enum.EasingStyle.Sine):Play()
            tw(U.ProgDot, 0.6, {BackgroundTransparency = 0.3, Size = UDim2.new(0, 12, 0, 12)}, Enum.EasingStyle.Sine):Play()
            task.wait(1.3)
        end
    end)
end

local function shineLoop()
    task.spawn(function()
        while not State.done and U.Card.Parent do
            U.Shine.Position = UDim2.new(-0.3, 0, 0, 0)
            tw(U.Shine, 1.2, {Position = UDim2.new(1.3, 0, 0, 0)}, Enum.EasingStyle.Linear):Play()
            task.wait(2)
        end
    end)
end

