            local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
            Services.TweenService:Create(notif, tweenInfo, { GroupTransparency = 0 }):Play()

            -- Countdown bar
            task.spawn(function()
                local start = tick()
                while tick() - start < duration do
                    local elapsed = tick() - start
                    local remaining = math.clamp(1 - (elapsed / duration), 0, 1)
                    barFill.Size = UDim2.new(remaining, 0, 1, 0)
                    task.wait()
                end

                -- Fade out
                local fadeInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
                Services.TweenService:Create(notif, fadeInfo, { GroupTransparency = 1 }):Play()
                task.wait(0.4)

                notif:Destroy()
            end)

            return notif
        end
    end
end

return Library
