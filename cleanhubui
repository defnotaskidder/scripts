                Items.DropdownHolder:TweenDescendants(Cfg.Open, Cfg)
                Items.DropdownHolder:ClampToScreen()

                Items.Arrow:Tween({Rotation = Cfg.Open and 270 or 90})

                if Cfg.Open then 
                    OnVisible() 
                else 
                    Invisible()
                end

                Items.ValueOther:Tween({TextTransparency = Cfg.Open and 0 or 1})

                for _, Option in Cfg.OptionInstances do                     
                    task.spawn(function()
                        Option.Text.Instance.Position = Cfg.Open and UDim2.new(-1, 0, 0, 0) or UDim2.new(0, 0, 0, 0)
