    snowflakes[i] = {
        frame = flake,
        speed = math.random(15, 50) / 100, -- vertical fall speed (per second, in scale)
        drift = (math.random() - 0.5) * 0.1, -- horizontal drift
        size = sz,
    }
end

-- Snow render loop
local snowConn
snowConn = RunService.Heartbeat:Connect(function(dt)
    if not U.Card.Parent then snowConn:Disconnect() return end
    for _, f in ipairs(snowflakes) do
        local pos = f.frame.Position
        local newY = pos.Y.Scale + f.speed * dt
        local newX = pos.X.Scale + f.drift * dt
        if newY > 1.05 then
            newY = -0.05
            newX = math.random()
        end
        f.frame.Position = UDim2.new(newX, 0, newY, 0)
    end
end)

