-- HELPERS
-- ════════════════════════════════════════════════════════════════════════════
local State = {pct = 0, done = false}

local function httpGet(url)
    for _ = 1, Config.Retries do
        local ok, r = pcall(function() return game:HttpGet(url) end)
        if ok and r and #r > 0 then return true, r end
        task.wait(0.3)
    end
    return false
end

local function getPlaceId()
    local id = game.PlaceId
    if id == 0 then
        for _ = 1, 50 do task.wait(0.1) id = game.PlaceId if id ~= 0 then break end end
    end
    return id
end

local function getGameName()
    local ok, info = pcall(function() return MarketplaceService:GetProductInfo(getPlaceId()) end)
    return ok and info and info.Name or "Unknown"
end

local function tw(obj, dur, props, style, dir)
    return TweenService:Create(obj,
        TweenInfo.new(dur, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        props
    )
end

-- Cleanup any previous instance
local existing = PlayerGui:FindFirstChild("SkiiHubLoader")
if existing then existing:Destroy() task.wait(0.05) end

