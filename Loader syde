    if child:IsA("Frame") then
        local target = 0
        if child == U.LogoGlow then target = 0.88
        elseif child == U.Div then target = 0.5
        elseif child == U.Shine then target = 0.7
        elseif child == U.ProgDot then target = 0.2
        elseif child == U.Snow then target = 1 -- keep snow container transparent
        elseif child.Parent == U.Snow then target = child.BackgroundTransparency
        elseif child == U.ProgBg then target = 0
        end
        tw(child, 0.35, {BackgroundTransparency = target}):Play()
    elseif child:IsA("TextLabel") then
        tw(child, 0.35, {TextTransparency = 0}):Play()
    elseif child:IsA("ImageLabel") then
        tw(child, 0.35, {ImageTransparency = 0}):Play()
    elseif child:IsA("UIStroke") then
        tw(child, 0.35, {Transparency = 0.4}):Play()
    end
    task.wait(0.005)
end

