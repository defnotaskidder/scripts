-- LOAD SCRIPT FOR CURRENT GAME
-- ════════════════════════════════════════════════════════════════════════════
task.spawn(function()
    local placeId = getPlaceId()
    local scriptUrl = Config.Scripts[placeId]
    local gameName = getGameName()

    if scriptUrl then
        U.GameDot.BackgroundColor3 = Color3.fromRGB(45, 200, 95)
        U.GameName.Text = gameName:sub(1, 40)
    else
        U.GameDot.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
        U.GameName.Text = "Not Supported (" .. tostring(placeId) .. ")"
        U.GameName.TextColor3 = Color3.fromRGB(255, 130, 140)
    end

    -- Loading stages
    local stageTime = Config.LoadTime / #Config.Stages
    for i, stage in ipairs(Config.Stages) do
        setStatus(stage.msg)
        activateDot(i)
        setProgress(stage.pct, stageTime * 0.85)
        task.wait(stageTime)
    end

    State.done = true
    tw(U.Shine, 0.3, {BackgroundTransparency = 1}):Play()
    tw(U.ProgDot, 0.3, {BackgroundTransparency = 1}):Play()

    local function destroy(delay)
        task.spawn(function()
            if delay then task.wait(delay) end
            if snowConn then snowConn:Disconnect() end
            tw(U.Blur, 0.4, {Size = 0}):Play()
            tw(U.Overlay, 0.3, {BackgroundTransparency = 1}):Play()
            for _, child in ipairs(U.Card:GetDescendants()) do
                if child:IsA("Frame") then tw(child, 0.3, {BackgroundTransparency = 1}):Play()
                elseif child:IsA("TextLabel") then tw(child, 0.3, {TextTransparency = 1}):Play()
                elseif child:IsA("ImageLabel") then tw(child, 0.3, {ImageTransparency = 1}):Play()
                elseif child:IsA("UIStroke") then tw(child, 0.3, {Transparency = 1}):Play()
                end
            end
            local outro = tw(U.Card, 0.4, {Size = UDim2.new(0, 0, 0, 0)}, Enum.EasingStyle.Back, Enum.EasingDirection.In)
            tw(U.Shadow, 0.4, {Size = UDim2.new(0, 0, 0, 0)}, Enum.EasingStyle.Back, Enum.EasingDirection.In):Play()
            outro:Play()
            outro.Completed:Wait()
            if U.Scr and U.Scr.Parent then U.Scr:Destroy() end
            if U.Blur and U.Blur.Parent then U.Blur:Destroy() end
        end)
    end

    if not scriptUrl then
        setStatus("Game not supported")
        tw(U.Stroke, 0.3, {Color = Color3.fromRGB(255, 70, 70)}):Play()
        tw(U.ProgFill, 0.3, {BackgroundColor3 = Color3.fromRGB(255, 70, 70)}):Play()
        U.Pct.TextColor3 = Color3.fromRGB(255, 70, 70)
        destroy(3.5)
        return
    end

    setStatus("Launching " .. gameName .. "...")

    local ok, err = pcall(function()
        local success, content = httpGet(scriptUrl)
        if not success then error("Download failed") end
        loadstring(content)()
    end)

    if ok then
        setStatus("Loaded successfully")
        tw(U.Stroke, 0.2, {Color = Color3.fromRGB(45, 200, 95), Transparency = 0}):Play()
        tw(U.TopBar, 0.3, {BackgroundColor3 = Color3.fromRGB(45, 200, 95)}):Play()
        task.wait(0.6)
        destroy()
    else
        setStatus("Failed: " .. tostring(err):sub(1, 30))
        tw(U.Stroke, 0.3, {Color = Color3.fromRGB(255, 70, 70)}):Play()
        tw(U.ProgFill, 0.3, {BackgroundColor3 = Color3.fromRGB(255, 70, 70)}):Play()
        U.Pct.TextColor3 = Color3.fromRGB(255, 70, 70)
        warn("[Skii Hub] Load error:", err)
        destroy(4)
    end
end)
